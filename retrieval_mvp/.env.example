# Copy this file to the repository root as .env.local, then replace the value.
# Never commit .env.local or paste the token into logs/chat.
PYSERINI_API_TOKEN=replace-with-token-issued-by-the-organizers

# Optional: only needed for --provider llm query rewriting.
# QUERY_REWRITE_BASE_URL=https://your-openai-compatible-endpoint/v1
# QUERY_REWRITE_API_KEY=replace-with-rewrite-model-key
# QUERY_REWRITE_MODEL=replace-with-model-name
