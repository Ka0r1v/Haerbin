# 示例：如何使用该函数构建并写入 JSONL 文件
# ==========================================
if __name__ == "__main__":
    # 模拟从 trec_rag_2026_queries.tsv 中读取的输入数据
    topic_id = "rag2026-37"
    topic_text = "I work for a New York City council member..."

    # 模拟您的模型检索、生成并拆分句子后的输出结果
    # 格式为: (句子文本, [支持该句子的原始文档ID列表])
    model_raw_outputs = [
        (
            "Congestion pricing should be assessed by whether it can provide reliable dedicated revenue.",
            ["shard_00459_61697", "shard_01012_88420"]
        ),
        (
            "A credible plan should also explain how environmental impacts and delivery concerns will be monitored.",
            ["shard_01012_88420", "shard_00210_44018"]
        )
    ]

    try:
        # 构建并运行内部校验
        json_line_data = build_and_validate_rag_entry(
            team_id="my-awesome-team",
            run_id="baseline-bm25-rag",
            run_desc="BM25 top-100 ClimbMix retrieval with LLM-grounded sentences.",
            narrative_id=topic_id,
            narrative=topic_text,
            raw_sentences=model_raw_outputs
        )
        
        # 写入 RAG 提交要求的 JSONL 格式文件
        output_filename = "rag_output_trec_rag_2026.jsonl"
        with open(output_filename, "a", encoding="utf-8") as f:
            f.write(json.dumps(json_line_data, ensure_ascii=False) + "\n")
            
        print(f"成功构建并写入一条记录到 {output_filename}！数据已通过所有硬性校验。")
        
    except ValueError as e:
        print(f"构建失败: {e}")
